<Window x:Class="SystemPulse.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:SystemPulse.Controls"
        Title="System Pulse"
        Width="336"
        Height="256"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        Loaded="Window_Loaded"
        Closed="Window_Closed">
    <Border x:Name="Shell"
            Background="#EE121722"
            BorderBrush="#3047A3C5"
            BorderThickness="1"
            CornerRadius="14"
            Padding="14"
            MouseLeftButtonDown="Shell_MouseLeftButtonDown">
        <Border.ContextMenu>
            <ContextMenu>
                <MenuItem Header="Exit" Click="Exit_Click" />
            </ContextMenu>
        </Border.ContextMenu>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="System Pulse"
                               Foreground="#F5F8FF"
                               FontSize="17"
                               FontWeight="SemiBold" />
                    <TextBlock x:Name="UpdatedText"
                               Text="Starting"
                               Foreground="#9AA8B8"
                               FontSize="11"
                               Margin="0,2,0,0" />
                </StackPanel>
                <Border Grid.Column="1"
                        Background="#1F68D391"
                        BorderBrush="#5068D391"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="8,3"
                        VerticalAlignment="Top">
                    <TextBlock Text="LIVE"
                               Foreground="#B7F7D1"
                               FontSize="10"
                               FontWeight="Bold" />
                </Border>
            </Grid>

            <Grid Grid.Row="1" Margin="0,13,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.05*" />
                    <ColumnDefinition Width="0.95*" />
                </Grid.ColumnDefinitions>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock x:Name="CpuValueText"
                                   Text="--%"
                                   Foreground="#40C9FF"
                                   FontSize="38"
                                   FontWeight="Bold" />
                        <TextBlock Text=" CPU"
                                   Foreground="#9AA8B8"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Margin="4,10,0,0" />
                    </StackPanel>
                    <controls:CpuHistoryChart x:Name="CpuChart"
                                              Grid.Row="1"
                                              Height="82"
                                              Margin="0,8,12,0" />
                </Grid>

                <StackPanel Grid.Column="1" Margin="4,0,0,0">
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="RAM"
                                   Foreground="#9AA8B8"
                                   FontSize="11"
                                   FontWeight="SemiBold" />
                        <TextBlock x:Name="MemoryText"
                                   Grid.Column="1"
                                   Text="-- / --"
                                   Foreground="#F5F8FF"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   TextAlignment="Right" />
                    </Grid>
                    <ProgressBar x:Name="MemoryBar"
                                 Height="5"
                                 Minimum="0"
                                 Maximum="100"
                                 Foreground="#7D7CFF"
                                 Background="#252C38"
                                 BorderThickness="0"
                                 Margin="0,0,0,13" />

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="GPU"
                                   Foreground="#9AA8B8"
                                   FontSize="11"
                                   FontWeight="SemiBold" />
                        <TextBlock x:Name="GpuText"
                                   Grid.Column="1"
                                   Text="Checking"
                                   Foreground="#F5F8FF"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   TextAlignment="Right" />
                    </Grid>
                    <ProgressBar x:Name="GpuBar"
                                 Height="5"
                                 Minimum="0"
                                 Maximum="100"
                                 Foreground="#68D391"
                                 Background="#252C38"
                                 BorderThickness="0"
                                 Margin="0,0,0,13" />

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="DISK"
                                   Foreground="#9AA8B8"
                                   FontSize="11"
                                   FontWeight="SemiBold" />
                        <TextBlock x:Name="DiskText"
                                   Grid.Column="1"
                                   Text="-- / --"
                                   Foreground="#F5F8FF"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   TextAlignment="Right" />
                    </Grid>
                    <ProgressBar x:Name="DiskBar"
                                 Height="5"
                                 Minimum="0"
                                 Maximum="100"
                                 Foreground="#FFB86B"
                                 Background="#252C38"
                                 BorderThickness="0" />
                </StackPanel>
            </Grid>

            <TextBlock Grid.Row="2"
                       Text="60-second CPU history"
                       Foreground="#748294"
                       FontSize="11"
                       HorizontalAlignment="Left" />
        </Grid>
    </Border>
</Window>
